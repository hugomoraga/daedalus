{
  "name": "daedalus",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "daedalus",
      "version": "0.0.0",
      "workspaces": [
        "packages/*",
        "apps/*",
        "tools/*"
      ],
      "engines": {
        "node": ">=22.6.0"
      }
    },
    "apps/atlas": {
      "name": "@daedalus/atlas",
      "version": "0.1.0",
      "dependencies": {
        "@daedalus/core": "*",
        "@daedalus/jsonl-event-store": "*",
        "@daedalus/revenue-visibility": "*"
      },
      "bin": {
        "atlas": "src/cli.ts"
      }
    },
    "apps/cli": {
      "name": "@daedalus/cli",
      "version": "0.0.0",
      "dependencies": {
        "@daedalus/core": "*",
        "@daedalus/jsonl-event-store": "*",
        "@daedalus/opportunity-discovery": "*",
        "@daedalus/proposal-generation": "*",
        "@daedalus/revenue-visibility": "*",
        "@daedalus/workflow-engine": "*"
      },
      "bin": {
        "daedalus": "src/index.ts"
      }
    },
    "node_modules/@daedalus/atlas": {
      "resolved": "apps/atlas",
      "link": true
    },
    "node_modules/@daedalus/atlas-seeder": {
      "resolved": "tools/atlas-seeder",
      "link": true
    },
    "node_modules/@daedalus/cli": {
      "resolved": "apps/cli",
      "link": true
    },
    "node_modules/@daedalus/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@daedalus/jsonl-event-store": {
      "resolved": "packages/jsonl-event-store",
      "link": true
    },
    "node_modules/@daedalus/opportunity-discovery": {
      "resolved": "packages/opportunity-discovery",
      "link": true
    },
    "node_modules/@daedalus/proposal-generation": {
      "resolved": "packages/proposal-generation",
      "link": true
    },
    "node_modules/@daedalus/revenue-visibility": {
      "resolved": "packages/revenue-visibility",
      "link": true
    },
    "node_modules/@daedalus/tax-compliance-guard": {
      "resolved": "packages/tax-compliance-guard",
      "link": true
    },
    "node_modules/@daedalus/theia": {
      "resolved": "tools/theia",
      "link": true
    },
    "node_modules/@daedalus/workflow-engine": {
      "resolved": "packages/workflow-engine",
      "link": true
    },
    "packages/core": {
      "name": "@daedalus/core",
      "version": "0.0.0"
    },
    "packages/jsonl-event-store": {
      "name": "@daedalus/jsonl-event-store",
      "version": "0.0.0",
      "dependencies": {
        "@daedalus/core": "*"
      }
    },
    "packages/opportunity-discovery": {
      "name": "@daedalus/opportunity-discovery",
      "version": "0.0.0",
      "dependencies": {
        "@daedalus/core": "*"
      }
    },
    "packages/proposal-generation": {
      "name": "@daedalus/proposal-generation",
      "version": "0.0.0",
      "dependencies": {
        "@daedalus/core": "*"
      }
    },
    "packages/revenue-visibility": {
      "name": "@daedalus/revenue-visibility",
      "version": "0.0.0",
      "dependencies": {
        "@daedalus/core": "*"
      }
    },
    "packages/tax-compliance-guard": {
      "name": "@daedalus/tax-compliance-guard",
      "version": "0.0.0",
      "dependencies": {
        "@daedalus/core": "*"
      }
    },
    "packages/workflow-engine": {
      "name": "@daedalus/workflow-engine",
      "version": "0.0.0",
      "dependencies": {
        "@daedalus/core": "*",
        "@daedalus/jsonl-event-store": "*",
        "@daedalus/proposal-generation": "*"
      }
    },
    "tools/atlas-seeder": {
      "name": "@daedalus/atlas-seeder",
      "version": "0.1.0",
      "dependencies": {
        "@daedalus/core": "*",
        "@daedalus/jsonl-event-store": "*"
      }
    },
    "tools/theia": {
      "name": "@daedalus/theia",
      "version": "0.1.0"
    }
  }
}
