# Daedalus — environment variables
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Pattern (Spec 008 Plan §4.1): tenant-specific values (currency, modules,
# thresholds, jurisdiction profile fields) live in env vars, never as
# hardcoded constants in committed .ts files. The `.ts` config files read
# from process.env with sensible defaults — without a `.env`, the system
# uses those defaults.
#
# NO PII goes here. Identity-bearing fields (provenance `verifiedBy`,
# human names, etc.) still go in `.env` because `.env` is gitignored —
# but treat `.env` as a secrets file.

# ── Tenant 0 — paramterizable fields ────────────────────────────────────
# Defaults match the values that were hardcoded before env-var support
# landed; leaving these unset reproduces pre-PR-031 behavior.

# ISO 4217 currency code (default: CLP)
TENANT_0_CURRENCY=CLP

# Comma-separated list of enabled module names
# (default: proposal-generation,revenue-visibility,opportunity-discovery)
TENANT_0_ENABLED_MODULES=proposal-generation,revenue-visibility,opportunity-discovery

# Revenue Visibility alert thresholds (Spec 001 §9)
TENANT_0_RUNWAY_FLOOR_MONTHS=3
TENANT_0_CONCENTRATION_CEILING_RATIO=0.6
TENANT_0_CASHFLOW_PERIOD_MONTHS=3

# ── Tenant 0 — future jurisdiction profile (Spec 008) ───────────────────
# Used only after config/tenants/tenant-0.jurisdiction.ts is created.
# The founder creates that file following Plan 008 §4.1. All values are
# optional; defaults match sensible Chile assumptions.

# ISO 3166-1 alpha-2 (default: CL)
TENANT_0_JURISDICTION_COUNTRY_CODE=CL
# State / province subdivision (optional). Default: empty (Chile IVA is
# national, no subdivision).
# TENANT_0_JURISDICTION_SUBDIVISION_CODE=RM

# Fiscal year start month (1-12) and day (1-31). Default: 1 / 1 (Chile
# fiscal year = calendar year).
TENANT_0_FY_START_MONTH=1
TENANT_0_FY_START_DAY=1

# Filing cadence: monthly | quarterly | annual | custom. Default: monthly
# (Chile IVA is monthly).
TENANT_0_FILING_CADENCE=monthly

# ISO date when this profile became active. Default: empty (until the
# founder populates).
# TENANT_0_PROFILE_EFFECTIVE_FROM=2026-01-01

# Rule provenance — `verifiedBy` is the human identity vouching for the
# rules. PII; keep `.env` out of git. Default: placeholder.
# TENANT_0_VERIFIED_BY=<founder>
# TENANT_0_PROVENANCE_RETRIEVED_AT=2026-01-01
# TENANT_0_PROVENANCE_SOURCE_ID=
# TENANT_0_PROVENANCE_SOURCE_KIND=tenant-declared
# TENANT_0_PROVENANCE_NOTES=